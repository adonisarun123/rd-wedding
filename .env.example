# Public site URL (Open Graph / metadata). On Vercel you can omit if VERCEL_URL is enough.
# NEXT_PUBLIC_SITE_URL=https://your-wedding.vercel.app

# Gmail SMTP (use an App Password, not your normal Gmail password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=accounts@monkmantra.com
# App passwords are 16 characters; spaces are optional (they are stripped automatically).
SMTP_PASS=your_app_password_here

# Who receives each RSVP (comma-separated for multiple inboxes).
RSVP_NOTIFY_EMAIL=couple@example.com

# Optional "From" header. Default: Wedding RSVP <SMTP_USER>
# RSVP_FROM_EMAIL=Roopashri & Dhakshinamoorthy <accounts@monkmantra.com>
